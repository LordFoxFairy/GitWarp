#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
export PATH="${HOME}/.local/bin:${PATH:-}"

python3 "${PLUGIN_ROOT}/skills/gitwarp/scripts/install_cli.py" >/dev/null 2>&1 || true

gitwarp_context=""
if [[ -f "${PLUGIN_ROOT}/skills/gitwarp/scripts/gitwarp.py" ]]; then
  gitwarp_context="$(python3 "${PLUGIN_ROOT}/skills/gitwarp/scripts/gitwarp.py" enter --cwd "$PWD" --format prompt 2>/dev/null || true)"
elif command -v gitwarp >/dev/null 2>&1; then
  gitwarp_context="$(gitwarp enter --cwd "$PWD" --format prompt 2>/dev/null || true)"
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

context="GitWarp plugin is installed.
Agent protocol:
1. Run gitwarp enter --cwd \"\$PWD\" before repository work.
2. For isolated or concurrent writes, use gitwarp start instead of git checkout/git switch.
3. In a worktree, read task.md, progress.md, and lessons.md before editing.
4. Record milestones with gitwarp handoff and finish with gitwarp finish.

Current context:
${gitwarp_context:-GitWarp context unavailable. Run gitwarp enter --cwd \"\$PWD\" manually.}"
context_escaped="$(escape_for_json "$context")"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context_escaped"
