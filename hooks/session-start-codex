#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
export PATH="${HOME}/.local/bin:${PATH:-}"

diagnostics=()
if ! command -v gitwarp >/dev/null 2>&1; then
  if ! install_output="$(python3 "${PLUGIN_ROOT}/skills/gitwarp/scripts/install_cli.py" 2>&1)"; then
    diagnostics+=("install_cli failed: ${install_output}")
  fi
fi

gitwarp_banner=""
if command -v gitwarp >/dev/null 2>&1; then
  if ! gitwarp_banner="$(gitwarp statusline --cwd "$PWD" 2>&1)"; then
    diagnostics+=("gitwarp statusline failed: ${gitwarp_banner}")
    gitwarp_banner=""
  fi
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

context="GitWarp: ${gitwarp_banner:-unavailable. Run gitwarp init, then gitwarp doctor.}
Use gitwarp create for isolated edits, gitwarp switch for existing sandboxes, and run gitwarp enter only when full dossier context is needed.
When assigned an existing worktree, leave it intact after verification unless the user explicitly asks for push, merge, remove, or collapse."
if [[ "${#diagnostics[@]}" -gt 0 ]]; then
  context="${context}

Diagnostics:"
  for diagnostic in "${diagnostics[@]}"; do
    context="${context}
- ${diagnostic//$'\n'/ }"
  done
fi
context_escaped="$(escape_for_json "$context")"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context_escaped"
