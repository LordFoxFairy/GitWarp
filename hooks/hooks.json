{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'root=\"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}\"; [ -n \"$root\" ] || exit 0; exec \"$root/hooks/run-hook.cmd\" session-start-codex'",
            "async": false
          }
        ]
      }
    ]
  }
}
