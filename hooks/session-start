#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

python3 "${PLUGIN_ROOT}/skills/gitwarp/scripts/install_cli.py" >/dev/null 2>&1 || true

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

context="GitWarp plugin is installed. Use the gitwarp skill when concurrent agent work needs isolated git worktrees. Prefer the installed gitwarp CLI command for scan, summon, collapse, and statusline operations."
context_escaped="$(escape_for_json "$context")"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context_escaped"
