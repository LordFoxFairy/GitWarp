#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
export PATH="${HOME}/.local/bin:${PATH:-}"

diagnostics=()
if ! install_output="$(python3 "${PLUGIN_ROOT}/skills/gitwarp/scripts/install_cli.py" 2>&1)"; then
  diagnostics+=("install_cli failed: ${install_output}")
fi

gitwarp_context=""
if command -v gitwarp >/dev/null 2>&1; then
  if ! gitwarp_context="$(gitwarp enter --cwd "$PWD" --format prompt 2>&1)"; then
    diagnostics+=("gitwarp enter failed: ${gitwarp_context}")
    gitwarp_context=""
  fi
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

context="GitWarp plugin is installed.
Agent protocol:
1. If GitWarp runtime is missing or doctor recommends it, run gitwarp init.
2. Use gitwarp statusline or gitwarp enter for context.
3. For isolated or concurrent writes, use gitwarp create or gitwarp dispatch instead of git checkout/git switch.
4. In a worktree, read task.md, progress.md, and lessons.md before editing.
5. Use gitwarp switch to navigate to existing sandboxes, gitwarp handoff for milestones, and gitwarp remove only when a sandbox is no longer needed.

Current GitWarp Context:
${gitwarp_context:-GitWarp Context: unavailable. Run gitwarp enter manually.}"
if [[ "${#diagnostics[@]}" -gt 0 ]]; then
  context="${context}

Diagnostics:"
  for diagnostic in "${diagnostics[@]}"; do
    context="${context}
- ${diagnostic//$'\n'/ }"
  done
fi
context_escaped="$(escape_for_json "$context")"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context_escaped"
